{
    "id" : "org.adb.gui",
    "runtime" : "org.gnome.Platform",
    "runtime-version" : "49",
    "sdk" : "org.gnome.Sdk",
    "command" : "org.adb.gui",
    "finish-args" : [
        "--share=network",
        "--share=ipc",
        "--socket=fallback-x11",
        "--device=all",
        "--socket=wayland"
    ],
    "cleanup" : [
        "/include",
        "/lib/pkgconfig",
        "/man",
        "/share/doc",
        "/share/gtk-doc",
        "/share/man",
        "/share/pkgconfig",
        "*.la",
        "*.a"
    ],
    "modules" : [
    	{
            "name" : "adb-binary",
            "buildsystem" : "simple",
            "sources" : [
                {
                    "type" : "archive",
                    "url" : "https://dl.google.com/android/repository/platform-tools_r37.0.0-linux.zip",
                    "sha256" : "198ae156ab285fa555987219af237b31102fefe8b9d2bc274708a8d4f2865a07"
                }
            ],
            "build-commands" : [
                "mkdir -p /app/bin",
                "cp adb /app/bin/adb",
                "cp fastboot /app/bin/fastboot",
                "chmod +x /app/bin/adb /app/bin/fastboot"
            ]
        },
        {
	    "name" : "adwaita-icon-theme",
	    "buildsystem" : "meson",
	    "sources" : [
		{
		    "type" : "git",
		    "url" : "https://gitlab.gnome.org/GNOME/adwaita-icon-theme.git",
		    "tag" : "49.0"
		}
	    ],
	    "cleanup" : [
		"/share/icons/Adwaita/cursors"
	    ]
	},
        {
	    "name" : "blueprint-compiler",
	    "buildsystem" : "meson",
	    "cleanup" : [ "*" ],
	    "sources" : [
		{
		    "type" : "git",
		    "url" : "https://gitlab.gnome.org/jwestman/blueprint-compiler.git",
		    "commit" : "5ede00481224252d3b13982a30fd21995b76c3a5"
		}
	    ]
	},
        {
            "name" : "adbgui",
            "builddir" : true,
            "buildsystem" : "meson",
            "sources" : [
                {
                    "type" : "git",
                    "path" : "."
                }
            ]
        }
    ]
}
